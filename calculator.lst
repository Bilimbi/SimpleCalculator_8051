     1  0000: 02 01 00      LJMP START
     2  0100:               ORG 100H ; Jump over debuger to the start of the program
     3  0100:           START:
     4  0100: 12 81 08      LCALL LCD_INIT
     5                  
     6  0103:           MAIN_LOOP:
     7  0103: 75 81 60  	MOV SP,#60H ; Set stack adress to the 60H
     8                  
     9  0106: 12 81 0C      LCALL LCD_CLR
    10                  
    11  0109: 78 30         MOV R0, #30H ; Point R0 to the first number storage location
    12  010B: 12 81 1E      LCALL GET_NUM ; Get the first number (stored in R0)
    13  010E: 78 30         MOV R0, #30H 
    14  0110: 12 81 20      LCALL BCD_HEX ; Convert the first number to hex
    15                  
    16                      ; Store the first number on the stack
    17  0113: C0 31         PUSH 31H ; [STACK] <- First num high byte
    18  0115: C0 30         PUSH 30H ; [STACK] <- First num low byte
    19                  
    20                      ; Get the operation
    21  0117: 12 81 1C      LCALL WAIT_KEY
    22  011A: B4 0A 03      CJNE A, #10, CHECK_SUB
    23  011D: 02 01 35      LJMP ADD_FUNC
    24                  
    25  0120:           CHECK_SUB:
    26  0120: B4 0B 03      CJNE A, #11, CHECK_MUL
    27  0123: 02 01 70      LJMP SUB_FUNC
    28                  
    29  0126:           CHECK_MUL:
    30  0126: B4 0C 03      CJNE A, #12, CHECK_DIV
    31  0129: 02 01 73      LJMP MUL_FUNC
    32                      
    33  012C:           CHECK_DIV:
    34  012C: B4 0D 03      CJNE A, #13, CHECK_DIV_NOT
    35  012F: 02 01 AC      LJMP DIV_FUNC
    36  0132:           CHECK_DIV_NOT:
    37  0132: 02 02 14      LJMP WRONG_OP
    38                  
    39                  ; --------------------------------------------------
    40                  ; \/ Operations \/
    41                  ; --------------------------------------------------
    42                  
    43  0135:           ADD_FUNC: ; Addition Function "A"
    44  0135: 74 2B         MOV A, #'+'
    45  0137: 12 81 02      LCALL WRITE_DATA
    46                  
    47  013A: 78 30         MOV R0, #30H 
    48  013C: 12 81 1E      LCALL GET_NUM ; Get the second number   
    49  013F: 78 30         MOV R0, #30H
    50  0141: 12 81 20      LCALL BCD_HEX
    51                  
    52  0144: 74 3D         MOV A, #'='
    53  0146: 12 81 02      LCALL WRITE_DATA
    54                  
    55  0149: D0 33         POP 33H ; First num low byte <- [STACK]
    56  014B: D0 32         POP 32H ; First num high byte <- [STACK]
    57                  
    58                      ; ----------------------------------------------
    59                      ; First number popped into 33H=LOW, 32H=HIGH
    60                      ; Second number is currently in 30H=LOW, 31H=HIGH
    61                      ; ----------------------------------------------
    62                  
    63                      ; Add the low bytes  
    64  014D: E5 30         MOV A, 30H           
    65  014F: 25 33         ADD A, 33H       
    66  0151: F5 30         MOV 30H, A 
    67                  
    68                      ; Add the high bytes with carry from the low byte addition
    69  0153: E5 31         MOV A, 31H   
    70  0155: 35 32         ADDC A, 32H       
    71  0157: F5 31         MOV 31H, A  
    72                  
    73                      ; Convert the result back to BCD
    74  0159: 78 30         MOV R0, #30H        
    75  015B: 12 81 22      LCALL HEX_BCD        
    76                      
    77                      ; Display the result 
    78  015E: E5 32         MOV A, 32H ; Highest byte (carry)
    79  0160: 12 81 04      LCALL WRITE_HEX
    80  0163: E5 31         MOV A, 31H ; High byte
    81  0165: 12 81 04      LCALL WRITE_HEX      
    82  0168: E5 30         MOV A, 30H ; Low byte
    83  016A: 12 81 04      LCALL WRITE_HEX
    84                  
    85  016D: 02 02 17      LJMP NEXT_OP
    86                      
    87  0170:           SUB_FUNC: ; Substraction Function "B"
    88  0170: 02 02 1D      LJMP STOP
    89                  
    90  0173:           MUL_FUNC: ; Multiplication Function "C"
    91  0173: 74 2A         MOV A, #'*'
    92  0175: 12 81 02      LCALL WRITE_DATA
    93                  
    94  0178: 78 30         MOV R0, #30H 
    95  017A: 12 81 1E      LCALL GET_NUM ; Get the second number   
    96  017D: 78 30         MOV R0, #30H
    97  017F: 12 81 20      LCALL BCD_HEX
    98                  
    99  0182: 74 3D         MOV A, #'='
   100  0184: 12 81 02      LCALL WRITE_DATA
   101                  
   102  0187: D0 33         POP 33H ; First num low byte <- [STACK]
   103  0189: D0 32         POP 32H ; First num high byte <- [STACK]
   104                  
   105                      ; ----------------------------------------------
   106                      ; Multiplicand = @R0 (30H=LOW,31H=HIGH), 
   107                      ; Multiplier = B,A (B=HIGH,A=LOW)
   108                      ; ----------------------------------------------
   109                  
   110  018B: E5 33         MOV A, 33H
   111  018D: 85 32 F0      MOV B, 32H
   112  0190: 78 30         MOV R0, #30H
   113  0192: 12 81 24      LCALL MUL_2_2
   114                  
   115                      ; Result (in hexadecimal) is 4 bytes at 30H - 33H
   116  0195: E5 33         MOV A, 33H
   117  0197: 12 81 04      LCALL WRITE_HEX
   118  019A: E5 32         MOV A, 32H
   119  019C: 12 81 04      LCALL WRITE_HEX
   120  019F: E5 31         MOV A, 31H
   121  01A1: 12 81 04      LCALL WRITE_HEX
   122  01A4: E5 30         MOV A, 30H
   123  01A6: 12 81 04      LCALL WRITE_HEX
   124                  
   125  01A9: 02 02 17      LJMP NEXT_OP
   126                  
   127  01AC:           DIV_FUNC: ; Division Function "D"
   128  01AC: 74 2F         MOV A, #'/'
   129  01AE: 12 81 02      LCALL WRITE_DATA
   130                  
   131  01B1: 78 36         MOV R0, #36H 
   132  01B3: 12 81 1E      LCALL GET_NUM ; Get the second number   
   133  01B6: 78 36         MOV R0, #36H
   134  01B8: 12 81 20      LCALL BCD_HEX
   135                  
   136  01BB: 74 3D         MOV A, #'='
   137  01BD: 12 81 02      LCALL WRITE_DATA
   138                  
   139  01C0: D0 35         POP 35H ; First num low byte <- [STACK]
   140  01C2: D0 34         POP 34H ; First num high byte <- [STACK]
   141                  
   142                      ; ----------------------------------------------
   143                      ; Dividend = @R0 (36H=HIGHEST,37H=LOWEST),
   144                      ; Divisor = B,A (B=HIGH,A=LOW)
   145                      ; ----------------------------------------------
   146                  
   147  01C4: E5 36         MOV A, 36H ; Divisor low byte
   148  01C6: 85 37 F0      MOV B, 37H ; Divisor high byte
   149                  
   150  01C9: 85 35 30      MOV 30H, 35H ; Dividend low byte
   151  01CC: 85 34 31      MOV 31H, 34H ; Dividend high byte
   152                      ; Zero 2 higher bytes \/
   153  01CF: 75 32 00      MOV 32H, #00H 
   154  01D2: 75 33 00      MOV 33H, #00H
   155                  
   156  01D5: 78 30         MOV R0, #30H
   157  01D7: 12 81 2A      LCALL DIV_4_2
   158                  
   159                      ; Convert the result back to BCD
   160  01DA: 78 30         MOV R0, #30H        
   161  01DC: 12 81 22      LCALL HEX_BCD ; Quotient
   162  01DF: 78 34         MOV R0, #34H
   163  01E1: 12 81 22      LCALL HEX_BCD ; Remainder
   164  01E4: 78 36         MOV R0, #36H
   165  01E6: 12 81 22      LCALL HEX_BCD ; Divisor
   166                  
   167                      ; Display the result 
   168  01E9: E5 31         MOV A, 31H ; High byte
   169  01EB: 12 81 04      LCALL WRITE_HEX      
   170  01EE: E5 30         MOV A, 30H ; Low byte
   171  01F0: 12 81 04      LCALL WRITE_HEX
   172                  
   173  01F3: 74 20         MOV A, #' '
   174  01F5: 12 81 02      LCALL WRITE_DATA
   175  01F8: E5 35         MOV A, 35H ; Remainder high byte
   176  01FA: 12 81 04      LCALL WRITE_HEX
   177  01FD: E5 34         MOV A, 34H ; Remainder low byte
   178  01FF: 12 81 04      LCALL WRITE_HEX
   179                  
   180  0202: 74 2F         MOV A, #'/'
   181  0204: 12 81 02      LCALL WRITE_DATA
   182  0207: E5 37         MOV A, 37H ; Divisor low byte
   183  0209: 12 81 04      LCALL WRITE_HEX
   184  020C: E5 36         MOV A, 36H ; Divisor high byte
   185  020E: 12 81 04      LCALL WRITE_HEX
   186                  
   187  0211: 02 02 17      LJMP NEXT_OP
   188                  
   189  0214:           WRONG_OP: ; Wrong operation key
   190  0214: 02 01 03      LJMP MAIN_LOOP
   191                  
   192  0217:           NEXT_OP:
   193  0217: 12 81 1A      LCALL WAIT_ENT_ESC ; Wait for the user to press "Enter" or "Escape"
   194  021A: 02 01 03      LJMP MAIN_LOOP
   195                  
   196  021D:           STOP:
   197  021D: 80 FE         SJMP $ ; Stopping the program
