     1  0000: 02 01 00      LJMP START
     2  0100:               ORG 100H ; Jump over debuger to the start of the program
     3  0100:           START:
     4  0100: 12 81 08      LCALL LCD_INIT
     5                  
     6  0103:           MAIN_LOOP:
     7  0103: 75 81 60  	MOV SP,#60H ; Set stack adress to the 60H
     8                  
     9  0106: 12 81 0C      LCALL LCD_CLR
    10                  
    11  0109: 78 30         MOV R0, #30H ; Point R0 to the first number storage location
    12  010B: 12 81 1E      LCALL GET_NUM ; Get the first number (stored in R0)
    13  010E: 78 30         MOV R0, #30H 
    14  0110: 12 81 20      LCALL BCD_HEX ; Convert the first number to hex
    15                  
    16                      ; Store the first number on the stack
    17  0113: C0 31         PUSH 31H ; [STACK] <- First num high byte
    18  0115: C0 30         PUSH 30H ; [STACK] <- First num low byte
    19                  
    20                      ; Get the operation
    21  0117: 12 81 1C      LCALL WAIT_KEY
    22  011A: B4 0A 02      CJNE A, #10, CHECK_SUB
    23  011D: 80 0F         SJMP ADD_FUNC
    24                  
    25  011F:           CHECK_SUB:
    26  011F: B4 0B 02      CJNE A, #11, CHECK_MUL
    27  0122: 80 44         SJMP SUB_FUNC
    28                  
    29  0124:           CHECK_MUL:
    30  0124: B4 0C 02      CJNE A, #12, CHECK_DIV
    31  0127: 80 41         SJMP MUL_FUNC
    32                      
    33  0129:           CHECK_DIV:
    34  0129: B4 0D 42      CJNE A, #13, WRONG_OP
    35  012C: 80 3E         SJMP DIV_FUNC
    36                  
    37                  ; --------------------------------------------------
    38                  ; \/ Operations \/
    39                  ; --------------------------------------------------
    40                  
    41  012E:           ADD_FUNC: ; Addition Function "A"
    42  012E: 74 2B         MOV A, #'+'
    43  0130: 12 81 02      LCALL WRITE_DATA
    44                  
    45  0133: 78 30         MOV R0, #30H 
    46  0135: 12 81 1E      LCALL GET_NUM ; Get the second number   
    47  0138: 78 30         MOV R0, #30H
    48  013A: 12 81 20      LCALL BCD_HEX
    49                  
    50  013D: 74 3D         MOV A, #'='
    51  013F: 12 81 02      LCALL WRITE_DATA
    52                  
    53  0142: D0 33         POP 33H ; First num low byte <- [STACK]
    54  0144: D0 32         POP 32H ; First num high byte <- [STACK]
    55                  
    56                  ; --------------------------------------------------
    57                  ; First number popped into 33H=LOW, 32H=HIGH
    58                  ; Second number is currently in 30H=LOW, 31H=HIGH
    59                  ; --------------------------------------------------
    60                  
    61                      ; Add the low bytes  
    62  0146: E5 30         MOV A, 30H           
    63  0148: 25 33         ADD A, 33H       
    64  014A: F5 30         MOV 30H, A 
    65                  
    66                      ; Add the high bytes with carry from the low byte addition
    67  014C: E5 31         MOV A, 31H   
    68  014E: 35 32         ADDC A, 32H       
    69  0150: F5 31         MOV 31H, A  
    70                  
    71                      ; Convert the result back to BCD
    72  0152: 78 30         MOV R0, #30H        
    73  0154: 12 81 22      LCALL HEX_BCD        
    74                      
    75                      ; Display the result 
    76  0157: E5 32         MOV A, 32H
    77  0159: 12 81 04      LCALL WRITE_HEX
    78  015C: E5 31         MOV A, 31H
    79  015E: 12 81 04      LCALL WRITE_HEX      
    80  0161: E5 30         MOV A, 30H
    81  0163: 12 81 04      LCALL WRITE_HEX
    82                  
    83  0166: 80 09         SJMP STOP
    84                      
    85  0168:           SUB_FUNC: ; Substraction Function "B"
    86  0168: 80 07         SJMP STOP
    87                  
    88  016A:           MUL_FUNC: ; Multiplication Function "C"
    89  016A: 80 05         SJMP STOP
    90                  
    91  016C:           DIV_FUNC: ; Division Function "D"
    92  016C: 80 03         SJMP STOP
    93                  
    94  016E:           WRONG_OP: ; Wrong operation key
    95  016E: 02 01 03      LJMP MAIN_LOOP
    96                  
    97  0171:           STOP:
    98  0171: 80 FE         SJMP $ ; Stopping the program
