     1  0000: 02 01 00      LJMP START
     2  0100:               ORG 100H ; Jump over debuger to the start of the program
     3  0100:           START:
     4  0100: 12 81 08      LCALL LCD_INIT
     5                  
     6  0103:           MAIN_LOOP:
     7  0103: 75 81 60  	MOV SP,#60H ; Set stack adress to the 60H
     8                  
     9  0106: 12 81 0C      LCALL LCD_CLR
    10                  
    11  0109: 78 30         MOV R0, #30H ; Point R0 to the first number storage location
    12  010B: 12 81 1E      LCALL GET_NUM ; Get the first number (stored in R0)
    13  010E: 78 30         MOV R0, #30H 
    14  0110: 12 81 20      LCALL BCD_HEX ; Convert the first number to hex
    15                  
    16                      ; Store the first number on the stack
    17  0113: C0 31         PUSH 31H ; [STACK] <- First num high byte
    18  0115: C0 30         PUSH 30H ; [STACK] <- First num low byte
    19                  
    20                      ; Get the operation
    21  0117: 12 81 1C      LCALL WAIT_KEY
    22  011A: B4 0A 03      CJNE A, #10, CHECK_SUB
    23  011D: 02 01 35      LJMP ADD_FUNC
    24                  
    25  0120:           CHECK_SUB:
    26  0120: B4 0B 03      CJNE A, #11, CHECK_MUL
    27  0123: 02 01 70      LJMP SUB_FUNC
    28                  
    29  0126:           CHECK_MUL:
    30  0126: B4 0C 03      CJNE A, #12, CHECK_DIV
    31  0129: 02 01 D9      LJMP MUL_FUNC
    32                      
    33  012C:           CHECK_DIV:
    34  012C: B4 0D 03      CJNE A, #13, CHECK_DIV_NOT
    35  012F: 02 02 12      LJMP DIV_FUNC
    36  0132:           CHECK_DIV_NOT:
    37  0132: 02 02 6A      LJMP WRONG_OP
    38                  
    39                  ; --------------------------------------------------
    40                  ; \/ Operations \/
    41                  ; --------------------------------------------------
    42                  
    43  0135:           ADD_FUNC: ; Addition Function "A"
    44  0135: 74 2B         MOV A, #'+'
    45  0137: 12 81 02      LCALL WRITE_DATA
    46                  
    47  013A: 78 30         MOV R0, #30H 
    48  013C: 12 81 1E      LCALL GET_NUM ; Get the second number   
    49  013F: 78 30         MOV R0, #30H
    50  0141: 12 81 20      LCALL BCD_HEX
    51                  
    52  0144: 74 3D         MOV A, #'='
    53  0146: 12 81 02      LCALL WRITE_DATA
    54                  
    55  0149: D0 33         POP 33H ; First num low byte <- [STACK]
    56  014B: D0 32         POP 32H ; First num high byte <- [STACK]
    57                  
    58                      ; ----------------------------------------------
    59                      ; First number popped into 33H=LOW, 32H=HIGH
    60                      ; Second number is currently in 30H=LOW, 31H=HIGH
    61                      ; ----------------------------------------------
    62                  
    63                      ; Add the low bytes  
    64  014D: E5 30         MOV A, 30H           
    65  014F: 25 33         ADD A, 33H       
    66  0151: F5 30         MOV 30H, A 
    67                  
    68                      ; Add the high bytes with carry from the low byte addition
    69  0153: E5 31         MOV A, 31H   
    70  0155: 35 32         ADDC A, 32H       
    71  0157: F5 31         MOV 31H, A  
    72                  
    73                      ; Convert the result back to BCD
    74  0159: 78 30         MOV R0, #30H        
    75  015B: 12 81 22      LCALL HEX_BCD        
    76                      
    77                      ; Display the result 
    78  015E: E5 32         MOV A, 32H ; Highest byte (carry)
    79  0160: 12 81 04      LCALL WRITE_HEX
    80  0163: E5 31         MOV A, 31H ; High byte
    81  0165: 12 81 04      LCALL WRITE_HEX      
    82  0168: E5 30         MOV A, 30H ; Low byte
    83  016A: 12 81 04      LCALL WRITE_HEX
    84                  
    85  016D: 02 02 6D      LJMP NEXT_OP
    86                      
    87  0170:           SUB_FUNC: ; Substraction Function "B"
    88  0170: 74 2D         MOV A, #'-'
    89  0172: 12 81 02      LCALL WRITE_DATA
    90                  
    91  0175: 78 30         MOV R0, #30H 
    92  0177: 12 81 1E      LCALL GET_NUM ; Get the second number   
    93  017A: 78 30         MOV R0, #30H
    94  017C: 12 81 20      LCALL BCD_HEX
    95                  
    96  017F: 74 3D         MOV A, #'='
    97  0181: 12 81 02      LCALL WRITE_DATA
    98                  
    99  0184: D0 33         POP 33H ; First num low byte <- [STACK]
   100  0186: D0 32         POP 32H ; First num high byte <- [STACK]
   101                  
   102                      ; Subtract the low bytes
   103  0188: E5 33         MOV A, 33H
   104  018A: C3            CLR C ; Clear carry for subtraction
   105  018B: 95 30         SUBB A, 30H
   106  018D: F5 30         MOV 30H, A
   107                  
   108                      ; Subtract the high bytes with borrow from the low byte subtraction
   109  018F: E5 32         MOV A, 32H
   110  0191: 95 31         SUBB A, 31H
   111  0193: F5 31         MOV 31H, A
   112                  
   113  0195: 50 30         JNC SUB_POS ; If no borrow, the result is positive or zero
   114                  
   115                      ; Negative result handling
   116  0197: E5 30         MOV A, 30H
   117  0199: F4            CPL A
   118  019A: F5 30         MOV 30H, A ; Invert the low byte
   119  019C: E5 31         MOV A, 31H
   120  019E: F4            CPL A
   121  019F: F5 31         MOV 31H, A ; Invert the high byte
   122                  
   123  01A1: 05 30         INC 30H ; +1 on low byte
   124  01A3: 70 02         JNZ SUB_MAG_OK ; If low byte is not zero after increment, skip the carry
   125  01A5: 05 31         INC 31H ; propagate carry to high byte if low byte was zero
   126                  
   127  01A7:           SUB_MAG_OK:
   128                  
   129  01A7: 78 30         MOV R0, #30H
   130  01A9: 12 81 22      LCALL HEX_BCD ; Convert the magnitude of the result to BCD
   131                  
   132  01AC: 74 2D         MOV A, #'-'
   133  01AE: 12 81 02      LCALL WRITE_DATA ; Display the negative sign
   134                  
   135  01B1: E5 32         MOV A, 32H 
   136  01B3: 54 0F         ANL A, #0FH ; Keep only the lowest BCD digit
   137  01B5: 24 30         ADD A, #'0'
   138  01B7: 12 81 02      LCALL WRITE_DATA
   139                  
   140  01BA: E5 31         MOV A, 31H
   141  01BC: 12 81 04      LCALL WRITE_HEX
   142  01BF: E5 30         MOV A, 30H
   143  01C1: 12 81 04      LCALL WRITE_HEX
   144                  
   145  01C4: 02 02 6D      LJMP NEXT_OP
   146                  
   147  01C7:           SUB_POS: ; Positive or '0' result from subtraction
   148                      ; Convert the result back to BCD
   149  01C7: 78 30         MOV R0, #30H        
   150  01C9: 12 81 22      LCALL HEX_BCD        
   151                      
   152                      ; Display the result
   153  01CC: E5 31         MOV A, 31H ; High byte
   154  01CE: 12 81 04      LCALL WRITE_HEX      
   155  01D1: E5 30         MOV A, 30H ; Low byte
   156  01D3: 12 81 04      LCALL WRITE_HEX
   157                  
   158  01D6: 02 02 6D      LJMP NEXT_OP
   159                  
   160  01D9:           MUL_FUNC: ; Multiplication Function "C"
   161  01D9: 74 2A         MOV A, #'*'
   162  01DB: 12 81 02      LCALL WRITE_DATA
   163                  
   164  01DE: 78 30         MOV R0, #30H 
   165  01E0: 12 81 1E      LCALL GET_NUM ; Get the second number   
   166  01E3: 78 30         MOV R0, #30H
   167  01E5: 12 81 20      LCALL BCD_HEX
   168                  
   169  01E8: 74 3D         MOV A, #'='
   170  01EA: 12 81 02      LCALL WRITE_DATA
   171                  
   172  01ED: D0 33         POP 33H ; First num low byte <- [STACK]
   173  01EF: D0 32         POP 32H ; First num high byte <- [STACK]
   174                  
   175                      ; ----------------------------------------------
   176                      ; Multiplicand = @R0 (30H=LOW,31H=HIGH), 
   177                      ; Multiplier = B,A (B=HIGH,A=LOW)
   178                      ; ----------------------------------------------
   179                  
   180  01F1: E5 33         MOV A, 33H
   181  01F3: 85 32 F0      MOV B, 32H
   182  01F6: 78 30         MOV R0, #30H
   183  01F8: 12 81 24      LCALL MUL_2_2
   184                  
   185                      ; Result (in hexadecimal) is 4 bytes at 30H - 33H
   186  01FB: E5 33         MOV A, 33H
   187  01FD: 12 81 04      LCALL WRITE_HEX
   188  0200: E5 32         MOV A, 32H
   189  0202: 12 81 04      LCALL WRITE_HEX
   190  0205: E5 31         MOV A, 31H
   191  0207: 12 81 04      LCALL WRITE_HEX
   192  020A: E5 30         MOV A, 30H
   193  020C: 12 81 04      LCALL WRITE_HEX
   194                  
   195  020F: 02 02 6D      LJMP NEXT_OP
   196                  
   197  0212:           DIV_FUNC: ; Division Function "D"
   198  0212: 74 2F         MOV A, #'/'
   199  0214: 12 81 02      LCALL WRITE_DATA
   200                  
   201  0217: 78 36         MOV R0, #36H 
   202  0219: 12 81 1E      LCALL GET_NUM ; Get the second number   
   203  021C: 78 36         MOV R0, #36H
   204  021E: 12 81 20      LCALL BCD_HEX
   205                  
   206  0221: 74 3D         MOV A, #'='
   207  0223: 12 81 02      LCALL WRITE_DATA
   208                  
   209  0226: D0 35         POP 35H ; First num low byte <- [STACK]
   210  0228: D0 34         POP 34H ; First num high byte <- [STACK]
   211                  
   212                      ; ----------------------------------------------
   213                      ; Dividend = @R0 (36H=HIGHEST,37H=LOWEST),
   214                      ; Divisor = B,A (B=HIGH,A=LOW)
   215                      ; ----------------------------------------------
   216                  
   217  022A: E5 36         MOV A, 36H ; Divisor low byte
   218  022C: 85 37 F0      MOV B, 37H ; Divisor high byte
   219                  
   220  022F: 85 35 30      MOV 30H, 35H ; Dividend low byte
   221  0232: 85 34 31      MOV 31H, 34H ; Dividend high byte
   222                      ; Zero 2 higher bytes \/
   223  0235: 75 32 00      MOV 32H, #00H 
   224  0238: 75 33 00      MOV 33H, #00H
   225                  
   226  023B: 78 30         MOV R0, #30H
   227  023D: 12 81 2A      LCALL DIV_4_2
   228                  
   229                      ; Convert the result back to BCD
   230  0240: 78 30         MOV R0, #30H        
   231  0242: 12 81 22      LCALL HEX_BCD ; Quotient
   232  0245: 78 34         MOV R0, #34H
   233  0247: 12 81 22      LCALL HEX_BCD ; Remainder
   234  024A: 78 36         MOV R0, #36H
   235  024C: 12 81 22      LCALL HEX_BCD ; Divisor (the second number)
   236                  
   237                      ; Display the result 
   238  024F: E5 31         MOV A, 31H ; High byte
   239  0251: 12 81 04      LCALL WRITE_HEX      
   240  0254: E5 30         MOV A, 30H ; Low byte
   241  0256: 12 81 04      LCALL WRITE_HEX
   242                  
   243  0259: 74 20         MOV A, #' '
   244  025B: 12 81 02      LCALL WRITE_DATA
   245  025E: E5 35         MOV A, 35H ; Remainder high byte
   246  0260: 12 81 04      LCALL WRITE_HEX
   247  0263: E5 34         MOV A, 34H ; Remainder low byte
   248  0265: 12 81 04      LCALL WRITE_HEX
   249                  
   250  0268: 80 03         SJMP NEXT_OP
   251                  
   252  026A:           WRONG_OP: ; Wrong operation key
   253  026A: 02 01 03      LJMP MAIN_LOOP
   254                  
   255  026D:           NEXT_OP:
   256  026D: 12 81 1A      LCALL WAIT_ENT_ESC ; Wait for the user to press "Enter" or "Escape"
   257  0270: 02 01 03      LJMP MAIN_LOOP
   258                  
   259  0273:           STOP:
   260  0273: 80 FE         SJMP $ ; Stopping the program
